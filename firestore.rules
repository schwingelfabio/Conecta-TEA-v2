rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - uid: string (required)
    //   - displayName: string (optional)
    //   - email: string (required)
    //   - photoURL: string (optional)
    //   - role: string (optional, enum: ["admin", "user", "vip"])
    //   - city: string (optional)
    //   - state: string (optional)
    //   - isVip: boolean (optional)
    //
    // Collection: sofia_users
    // Document ID: {userId}
    // Fields:
    //   - id: string (required)
    //   - name: string (optional)
    //   - childName: string (optional)
    //   - childAge: number (optional)
    //   - mainConcerns: array of strings (optional)
    //   - createdAt: string (date-time, optional)
    //
    // [Other collections follow similar patterns]
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         request.auth.token.email == "fabiopalacioschwingel@gmail.com");
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function validStringLength(field, minLen, maxLen) {
      return request.resource.data[field] is string &&
        request.resource.data[field].size() >= minLen &&
        request.resource.data[field].size() <= maxLen;
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email']) &&
             data.uid is string &&
             data.email is string &&
             (!('role' in data) || data.role in ['admin', 'user', 'vip', 'parent', 'professional', 'autistic', 'other']) &&
             (!('displayName' in data) || data.displayName is string && data.displayName.size() < 100) &&
             (!('photoURL' in data) || data.photoURL is string && data.photoURL.size() < 1000) &&
             (!('city' in data) || data.city is string && data.city.size() < 100) &&
             (!('state' in data) || data.state is string && data.state.size() < 100) &&
             (!('isVip' in data) || data.isVip is bool);
    }

    function isValidPublicProfile(data) {
      return data.keys().hasAll(['uid']) &&
             data.uid is string &&
             (!('role' in data) || data.role in ['admin', 'user', 'vip', 'parent', 'professional', 'autistic', 'other']) &&
             (!('displayName' in data) || data.displayName is string && data.displayName.size() < 100) &&
             (!('photoURL' in data) || data.photoURL is string && data.photoURL.size() < 1000) &&
             (!('city' in data) || data.city is string && data.city.size() < 100) &&
             (!('state' in data) || data.state is string && data.state.size() < 100) &&
             (!('isVip' in data) || data.isVip is bool);
    }

    function isValidSofiaUser(data) {
      return data.keys().hasOnly(['id', 'name', 'childName', 'childAge', 'mainConcerns', 'createdAt']) &&
             data.id is string &&
             (!('name' in data) || data.name is string && data.name.size() < 100) &&
             (!('childName' in data) || data.childName is string && data.childName.size() < 100) &&
             (!('childAge' in data) || data.childAge is number && data.childAge >= 0) &&
             (!('mainConcerns' in data) || data.mainConcerns is list && data.mainConcerns.size() < 20);
    }

    function isValidSosCard(data) {
      return data.keys().hasAll(['userId', 'childName', 'createdAt', 'updatedAt']) &&
             data.userId is string &&
             data.childName is string && data.childName.size() < 100 &&
             (!('officialId' in data) || data.officialId is string) &&
             (!('birthDate' in data) || data.birthDate is string) &&
             (!('bloodType' in data) || data.bloodType is string && data.bloodType.size() < 10) &&
             (!('allergies' in data) || data.allergies is string && data.allergies.size() < 500) &&
             (!('observations' in data) || data.observations is string && data.observations.size() < 1000) &&
             (!('contact1Name' in data) || data.contact1Name is string && data.contact1Name.size() < 100) &&
             (!('contact1Phone' in data) || data.contact1Phone is string && data.contact1Phone.size() < 20) &&
             (!('contact2Name' in data) || data.contact2Name is string && data.contact2Name.size() < 100) &&
             (!('contact2Phone' in data) || data.contact2Phone is string && data.contact2Phone.size() < 20) &&
             (!('homeAddress' in data) || data.homeAddress is string && data.homeAddress.size() < 500) &&
             (!('workAddress' in data) || data.workAddress is string && data.workAddress.size() < 500) &&
             (!('city' in data) || data.city is string && data.city.size() < 100) &&
             (!('state' in data) || data.state is string && data.state.size() < 100) &&
             (!('responsibleName' in data) || data.responsibleName is string && data.responsibleName.size() < 100) &&
             (!('emergencyNote' in data) || data.emergencyNote is string && data.emergencyNote.size() < 1000) &&
             data.createdAt is timestamp &&
             data.updatedAt is timestamp;
    }

    // ===============================================================
    // Match Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidUser(request.resource.data) && 
                    (isAdmin() || ((!('role' in request.resource.data) || request.resource.data.role != 'admin') && (!('isVip' in request.resource.data) || request.resource.data.isVip == false)));
      allow update: if (isOwner(userId) && isValidUser(request.resource.data) && 
                    (!('role' in request.resource.data) || request.resource.data.role in ['parent', 'professional', 'autistic', 'other', 'user'] || request.resource.data.role == resource.data.role) &&
                    (!('isVip' in request.resource.data) || request.resource.data.isVip == resource.data.isVip)) || isAdmin();
      allow delete: if isAdmin();
    }

    match /public_profiles/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId) && isValidPublicProfile(request.resource.data) && 
                    (isAdmin() || ((!('role' in request.resource.data) || request.resource.data.role != 'admin') && (!('isVip' in request.resource.data) || request.resource.data.isVip == false)));
      allow update: if (isOwner(userId) && isValidPublicProfile(request.resource.data) && 
                    (!('role' in request.resource.data) || request.resource.data.role in ['parent', 'professional', 'autistic', 'other', 'user'] || request.resource.data.role == resource.data.role) &&
                    (!('isVip' in request.resource.data) || request.resource.data.isVip == resource.data.isVip)) || isAdmin();
      allow delete: if isAdmin();
    }

    match /sofia_users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidSofiaUser(request.resource.data);
      allow update: if isOwner(userId) && isValidSofiaUser(request.resource.data);
    }

    match /sofia_sessions/{sessionId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.userId || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && (request.auth.uid == resource.data.userId || isAdmin());
    }

    match /sofia_messages/{messageId} {
      allow read: if isAuthenticated() && (get(/databases/$(database)/documents/sofia_sessions/$(resource.data.sessionId)).data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && get(/databases/$(database)/documents/sofia_sessions/$(request.resource.data.sessionId)).data.userId == request.auth.uid;
    }

    match /sofia_safety_events/{eventId} {
      allow read: if isAuthenticated() && (get(/databases/$(database)/documents/sofia_sessions/$(resource.data.sessionId)).data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && get(/databases/$(database)/documents/sofia_sessions/$(request.resource.data.sessionId)).data.userId == request.auth.uid;
    }

    match /sofia_summaries/{summaryId} {
      allow read: if isAuthenticated() && (get(/databases/$(database)/documents/sofia_sessions/$(resource.data.sessionId)).data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && get(/databases/$(database)/documents/sofia_sessions/$(request.resource.data.sessionId)).data.userId == request.auth.uid;
    }

    match /sos_cards/{cardId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid && isValidSosCard(request.resource.data);
      allow update: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin()) && isValidSosCard(request.resource.data);
    }

    match /meta/counters {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    match /videos/{videoId} {
      allow read: if isAuthenticated() || isAdmin();
      allow write: if isAdmin();
    }

    match /test_connection/{docId} {
      allow read, write: if true;
    }
    match /posts/{postId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && (request.resource.data.authorId == request.auth.uid || (request.resource.data.authorId == 'ai-bot' && isAdmin()));
      allow update: if isAuthenticated() && (resource.data.authorId == request.auth.uid || isAdmin());
      allow delete: if isAuthenticated() && (resource.data.authorId == request.auth.uid || isAdmin());
    }
    match /system_logs/{logId} {
      allow read: if isAdmin();
      allow write: if isAdmin() || request.resource.data.secretKey == 'conecta-tea-system-secret-key';
    }

    match /system_audits/{auditId} {
      allow read: if isAdmin();
      allow write: if isAdmin() || request.resource.data.secretKey == 'conecta-tea-system-secret-key';
    }

    match /system_fix_suggestions/{suggestionId} {
      allow read: if isAdmin();
      allow write: if isAdmin() || request.resource.data.secretKey == 'conecta-tea-system-secret-key';
    }

    match /system_reports/{reportId} {
      allow read: if isAdmin();
      allow write: if isAdmin() || request.resource.data.secretKey == 'conecta-tea-system-secret-key';
    }

    match /system_metrics/{metricId} {
      allow read: if isAdmin();
      allow write: if isAdmin() || request.resource.data.secretKey == 'conecta-tea-system-secret-key';
    }

    match /monetization_logs/{logId} {
      allow read: if isAdmin();
      allow write: if isAdmin() || request.resource.data.secretKey == 'conecta-tea-system-secret-key';
    }

    match /monetization_metrics/{metricId} {
      allow read: if isAdmin();
      allow write: if isAdmin() || request.resource.data.secretKey == 'conecta-tea-system-secret-key';
    }

    match /monetization_suggestions/{suggestionId} {
      allow read: if isAdmin();
      allow write: if isAdmin() || request.resource.data.secretKey == 'conecta-tea-system-secret-key';
    }
  }
}
