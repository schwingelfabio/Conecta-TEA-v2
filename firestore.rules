rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - uid: string (required)
    //   - displayName: string (optional)
    //   - email: string (required)
    //   - photoURL: string (optional)
    //   - role: string (optional, enum: ["admin", "user", "vip"])
    //   - city: string (optional)
    //   - state: string (optional)
    //   - isVip: boolean (optional)
    //
    // Collection: sofia_users
    // Document ID: {userId}
    // Fields:
    //   - id: string (required)
    //   - name: string (optional)
    //   - childName: string (optional)
    //   - childAge: number (optional)
    //   - mainConcerns: array of strings (optional)
    //   - createdAt: string (date-time, optional)
    //
    // [Other collections follow similar patterns]
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         request.auth.token.email == "fabiopalacioschwingel@gmail.com");
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function validStringLength(field, minLen, maxLen) {
      return request.resource.data[field] is string &&
        request.resource.data[field].size() >= minLen &&
        request.resource.data[field].size() <= maxLen;
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidSofiaUser(data) {
      return data.keys().hasOnly(['id', 'name', 'childName', 'childAge', 'mainConcerns', 'createdAt']) &&
             data.id is string &&
             (!('name' in data) || data.name is string && data.name.size() < 100) &&
             (!('childName' in data) || data.childName is string && data.childName.size() < 100) &&
             (!('childAge' in data) || data.childAge is number && data.childAge >= 0) &&
             (!('mainConcerns' in data) || data.mainConcerns is list && data.mainConcerns.size() < 20);
    }

    // ===============================================================
    // Match Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId) || isAdmin();
    }

    match /sofia_users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidSofiaUser(request.resource.data);
      allow update: if isOwner(userId) && isValidSofiaUser(request.resource.data);
    }

    match /sofia_sessions/{sessionId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.userId || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && (request.auth.uid == resource.data.userId || isAdmin());
    }

    match /sofia_messages/{messageId} {
      allow read: if isAuthenticated() && (get(/databases/$(database)/documents/sofia_sessions/$(resource.data.sessionId)).data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && get(/databases/$(database)/documents/sofia_sessions/$(request.resource.data.sessionId)).data.userId == request.auth.uid;
    }
  }
}
