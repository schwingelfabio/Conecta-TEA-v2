rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is admin
    function isAdmin() {
      return request.auth != null && (
        request.auth.token.email == 'fabiopalacioschwingel@gmail.com' || 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
    }
    
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    match /{document=**} {
      // Admin has full read/write access
      allow read, write: if isAdmin();
      
      // Authenticated users have read access to everything
      allow read: if isAuthenticated();
    }
    
    // Users can write their own data
    match /users/{userId} {
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Allow authenticated users to read admins
    match /admins/{email} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Allow authenticated users to create and read topics
    match /topics/{topicId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin();
    }
    
    // Users can create and edit posts
    match /posts/{postId} {
      allow create: if isAuthenticated() && (request.resource.data.topic != 'noticias' || isAdmin());
      allow update, delete: if isAuthenticated() && request.auth.uid == resource.data.authorId && (resource.data.topic != 'noticias' || isAdmin());
    }
    
    // Users can create and edit their own SOS cards
    match /sos_cards/{cardId} {
      // Public read access for emergency situations (QR scan)
      allow read: if true;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && request.auth.uid == resource.data.userId 
                    && (!('officialId' in resource.data) || request.resource.data.officialId == resource.data.officialId);
      allow delete: if isAuthenticated() && request.auth.uid == resource.data.userId;
    }

    // Global counters for ID generation
    match /meta/counters {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // Allow authenticated users to submit suggestions
    match /suggestions/{suggestionId} {
      allow create: if isAuthenticated();
      allow read, update, delete: if isAdmin();
    }
  }
}
