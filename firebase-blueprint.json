{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "user", "vip"] },
        "city": { "type": "string" },
        "state": { "type": "string" },
        "isVip": { "type": "boolean" }
      },
      "required": ["uid", "email"]
    },
    "PublicProfile": {
      "title": "PublicProfile",
      "description": "Public user profile information for maps and communities",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "user", "vip"] },
        "city": { "type": "string" },
        "state": { "type": "string" },
        "isVip": { "type": "boolean" }
      },
      "required": ["uid"]
    },
    "Post": {
      "title": "Post",
      "description": "Community post",
      "type": "object",
      "properties": {
        "text": { "type": "string" },
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "authorPhoto": { "type": "string" },
        "topic": { "type": "string" },
        "location": { "type": "string" },
        "timestamp": { "type": "object" },
        "isPinned": { "type": "boolean" },
        "isVip": { "type": "boolean" },
        "likes": { "type": "array", "items": { "type": "string" } },
        "commentsCount": { "type": "number" }
      },
      "required": ["text", "authorId", "topic"]
    },
    "Video": {
      "title": "Video",
      "description": "Educational video",
      "type": "object",
      "properties": {
        "videoId": { "type": "string" },
        "url": { "type": "string" },
        "title": { "type": "string" },
        "thumbnail": { "type": "string" },
        "createdAt": { "type": "object" }
      },
      "required": ["videoId", "url"]
    },
    "SosCard": {
      "title": "SosCard",
      "description": "Emergency identification card",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "officialId": { "type": "string" },
        "childName": { "type": "string" },
        "birthDate": { "type": "string" },
        "bloodType": { "type": "string" },
        "allergies": { "type": "string" },
        "observations": { "type": "string" },
        "contact1Name": { "type": "string" },
        "contact1Phone": { "type": "string" },
        "contact2Name": { "type": "string" },
        "contact2Phone": { "type": "string" },
        "homeAddress": { "type": "string" },
        "workAddress": { "type": "string" },
        "city": { "type": "string" },
        "state": { "type": "string" },
        "responsibleName": { "type": "string" },
        "emergencyNote": { "type": "string" },
        "createdAt": { "type": "object" },
        "updatedAt": { "type": "object" }
      },
      "required": ["userId", "childName"]
    },
    "SofiaUser": {
      "title": "SofiaUser",
      "description": "User profile for Sofia IA",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "childName": { "type": "string" },
        "childAge": { "type": "number" },
        "mainConcerns": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id"]
    },
    "SofiaSession": {
      "title": "SofiaSession",
      "description": "A conversation session with Sofia IA",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "startedAt": { "type": "string", "format": "date-time" },
        "endedAt": { "type": "string", "format": "date-time" },
        "mode": { "type": "string" },
        "urgentFlag": { "type": "boolean" }
      },
      "required": ["id", "startedAt", "mode"]
    },
    "SofiaMessage": {
      "title": "SofiaMessage",
      "description": "A message in a Sofia IA session",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "sessionId": { "type": "string" },
        "sender": { "type": "string", "enum": ["user", "sofia"] },
        "text": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "detectedEmotion": { "type": "string" }
      },
      "required": ["id", "sessionId", "sender", "text", "timestamp"]
    },
    "SofiaSummary": {
      "title": "SofiaSummary",
      "description": "Summary of a Sofia IA session",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "sessionId": { "type": "string" },
        "summaryText": { "type": "string" },
        "feelings": { "type": "array", "items": { "type": "string" } },
        "orientations": { "type": "array", "items": { "type": "string" } },
        "nextSteps": { "type": "array", "items": { "type": "string" } },
        "resources": { "type": "array", "items": { "type": "object" } }
      },
      "required": ["id", "sessionId", "summaryText"]
    },
    "SofiaSafetyEvent": {
      "title": "SofiaSafetyEvent",
      "description": "A safety event triggered during a Sofia IA session",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "sessionId": { "type": "string" },
        "type": { "type": "string" },
        "severity": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "details": { "type": "string" }
      },
      "required": ["id", "sessionId", "type", "severity", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/public_profiles/{userId}": {
      "schema": "PublicProfile",
      "description": "Public user profiles for map and community views"
    },
    "/posts/{postId}": {
      "schema": "Post",
      "description": "Community posts"
    },
    "/videos/{videoId}": {
      "schema": "Video",
      "description": "Educational videos"
    },
    "/sos_cards/{cardId}": {
      "schema": "SosCard",
      "description": "Emergency cards"
    },
    "/sofia_users/{userId}": {
      "schema": "SofiaUser",
      "description": "Sofia IA user profiles"
    },
    "/sofia_sessions/{sessionId}": {
      "schema": "SofiaSession",
      "description": "Sofia IA sessions"
    },
    "/sofia_messages/{messageId}": {
      "schema": "SofiaMessage",
      "description": "Sofia IA messages"
    },
    "/sofia_summaries/{summaryId}": {
      "schema": "SofiaSummary",
      "description": "Sofia IA session summaries"
    },
    "/sofia_safety_events/{eventId}": {
      "schema": "SofiaSafetyEvent",
      "description": "Sofia IA safety events"
    }
  }
}
